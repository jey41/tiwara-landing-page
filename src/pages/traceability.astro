---
import Layout from '../layouts/Layout.astro';
import TraceabilityView from '../components/Traceability.jsx';

// Traceability Portal Colors
const themeColors = {
  'color-primary-val': '#0B3D2E', // Forest Green
  'color-forest-val': '#0B3D2E', // Forest Green
  'color-secondary-val': '#20B2AA', // Scientific Teal
  'color-bg-light-val': '#FDFBF7',
  'color-bg-dark-val': '#0B3D2E',
};
---

<Layout title="TIWARA | Traceability Portal" themeColors={themeColors}>
	<TraceabilityView client:load />
</Layout>
